@model SistemadeVentas.EN.Usuario

@{
    ViewData["Title"] = "Crear Usuario";
}

<style>
    .form-wrapper {
        max-width: 520px;
        margin: 2rem auto;
        background: #0f2240;
        border: 1px solid #1e3a5f;
        border-radius: 12px;
        padding: 2rem;
    }
    .form-title { color: #f1f5f9; font-size: 22px; font-weight: 500; margin-bottom: 1.5rem; }
    .field { margin-bottom: 1.2rem; }
    .field label { display: block; color: #94a3b8; font-size: 13px; margin-bottom: 6px; }
    .field input, .field select {
        width: 100%;
        background: #162d4a;
        border: 1px solid #1e3a5f;
        color: #f1f5f9;
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 14px;
    }
    .field input:focus, .field select:focus { outline: none; border-color: #3b82f6; }
    .field select option { background: #0f2240; }
    .btn-guardar { background: #1d4ed8; color: #fff; border: none; padding: 10px 24px; border-radius: 8px; font-size: 14px; cursor: pointer; margin-right: 8px; }
    .btn-guardar:hover { background: #1e40af; }
    .btn-cancelar { background: transparent; color: #94a3b8; border: 1px solid #1e3a5f; padding: 10px 24px; border-radius: 8px; font-size: 14px; text-decoration: none; }
    .btn-cancelar:hover { background: #162d4a; color: #f1f5f9; }
    .val-error { color: #ef4444; font-size: 12px; margin-top: 4px; display: block; }
</style>

<div class="form-wrapper">
    <div class="form-title">Crear Usuario</div>
    <form asp-action="Crear" method="post">
        @Html.AntiForgeryToken()
        <div class="field">
            <label>Nombre</label>
            <input asp-for="Nombre" placeholder="Ingresa el nombre" />
            <span asp-validation-for="Nombre" class="val-error"></span>
        </div>
        <div class="field">
            <label>Apellido</label>
            <input asp-for="Apellido" placeholder="Ingresa el apellido" />
            <span asp-validation-for="Apellido" class="val-error"></span>
        </div>
        <div class="field">
            <label>Teléfono</label>
            <input asp-for="Telefono" placeholder="Ingresa el teléfono" />
            <span asp-validation-for="Telefono" class="val-error"></span>
        </div>
        <div class="field">
            <label>Contraseña</label>
            <input asp-for="Clave" type="password" placeholder="••••••••" />
            <span asp-validation-for="Clave" class="val-error"></span>
        </div>
        <div class="field">
            <label>Rol</label>
            <select asp-for="IdRol" asp-items="ViewBag.Roles">
                <option value="">-- Selecciona un rol --</option>
            </select>
            <span asp-validation-for="IdRol" class="val-error"></span>
        </div>
        <div class="field">
            <label>Estado</label>
            <select asp-for="Estado">
                <option value="Activo">Activo</option>
                <option value="Inactivo">Inactivo</option>
            </select>
        </div>
        <div style="margin-top: 1.5rem;">
            <button type="submit" class="btn-guardar">Guardar</button>
            <a asp-action="Index" class="btn-cancelar">Cancelar</a>
        </div>
    </form>
</div>