@model SistemadeVentas.EN.Usuario

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<h2>¿Eliminar este usuario?</h2>

<div class="card bg-dark text-white p-3">
    <p><strong>Nombre:</strong> @Model.Nombre @Model.Apellido</p>
    <p><strong>Teléfono:</strong> @Model.Telefono</p>
    <p><strong>Estado:</strong> @Model.Estado</p>
</div>

<form asp-action="EliminarConfirmado" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input name="id" type="hidden" value="@Model.IdUsuario" />
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>