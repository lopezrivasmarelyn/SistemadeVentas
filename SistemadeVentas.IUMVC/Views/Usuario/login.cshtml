@model Usuario

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-wrapper">
    <div class="login-card">
        <h1 class="login-title">Bienvenido a PC Hardware Hub</h1>
        <p class="login-subtitle">Inicia sesión o crea una cuenta para continuar</p>

        <div class="tabs-dark">
            <button class="tab-btn-dark active">Iniciar Sesión</button>
            <button class="tab-btn-dark inactive"
                    onclick="window.location.href='@Url.Action("Crear", "Usuario")'">
                Registrarse
            </button>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert-dark-error">@ViewBag.Error</div>
        }

        <form asp-action="Login" asp-controller="Usuario" method="post">
            @Html.AntiForgeryToken()

            <label class="form-label-dark">Teléfono</label>
            <input asp-for="Telefono" class="form-input-dark" placeholder="Ingresa tu teléfono" />
            <span asp-validation-for="Telefono" class="val-error"></span>

            <label class="form-label-dark">Contraseña</label>
            <input asp-for="Clave" type="password" class="form-input-dark" placeholder="••••••••" />
            <span asp-validation-for="Clave" class="val-error"></span>

            <button type="submit" class="btn-purple-full" style="margin-top:0.5rem;">
                Iniciar Sesión
            </button>
        </form>

        <div class="login-divider">o</div>

        <button class="btn-outline-dark" style="width:100%;"
                onclick="window.location.href='@Url.Action("Index", "Producto")'">
            Continuar como invitado
        </button>
    </div>
</div>