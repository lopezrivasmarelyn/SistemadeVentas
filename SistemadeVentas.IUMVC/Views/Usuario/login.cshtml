@model Usuario

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .login-page {
        min-height: 100vh;
        background: #0a1628;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .login-card {
        background: #0f2240;
        border: 1px solid #1e3a5f;
        border-radius: 12px;
        padding: 2rem;
        width: 100%;
        max-width: 420px;
    }

    .login-title {
        color: #f1f5f9;
        font-size: 1.5rem;
        font-weight: 500;
        text-align: center;
        margin-bottom: 0.25rem;
    }

    .login-subtitle {
        color: #64748b;
        font-size: 0.875rem;
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .tab-container {
        display: flex;
        background: #0a1628;
        border-radius: 8px;
        padding: 4px;
        margin-bottom: 1.5rem;
    }

    .tab-btn {
        flex: 1;
        padding: 0.5rem;
        border: none;
        border-radius: 6px;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .tab-btn.active {
        background: #0f2240;
        color: #f1f5f9;
        font-weight: 500;
    }

    .tab-btn.inactive {
        background: transparent;
        color: #64748b;
    }

    .tab-btn.inactive:hover {
        color: #94a3b8;
    }

    .field-label {
        display: block;
        color: #94a3b8;
        font-size: 13px;
        margin-bottom: 6px;
    }

    .field-input {
        width: 100%;
        background: #162d4a;
        border: 1px solid #1e3a5f;
        color: #f1f5f9;
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 14px;
        margin-bottom: 1rem;
        box-sizing: border-box;
    }

    .field-input:focus {
        outline: none;
        border-color: #3b82f6;
    }

    .field-input::placeholder {
        color: #475569;
    }

    .btn-ingresar {
        width: 100%;
        background: #1d4ed8;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.875rem;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        margin-top: 0.5rem;
        transition: background 0.2s;
    }

    .btn-ingresar:hover {
        background: #1e40af;
    }

    .divider {
        text-align: center;
        color: #475569;
        font-size: 0.875rem;
        margin: 1rem 0;
        position: relative;
    }

    .divider::before, .divider::after {
        content: '';
        position: absolute;
        top: 50%;
        width: 44%;
        height: 1px;
        background: #1e3a5f;
    }

    .divider::before { left: 0; }
    .divider::after { right: 0; }

    .btn-invitado {
        width: 100%;
        background: transparent;
        color: #94a3b8;
        border: 1px solid #1e3a5f;
        border-radius: 8px;
        padding: 0.75rem;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-invitado:hover {
        background: #162d4a;
        color: #f1f5f9;
    }

    .error-box {
        background: #1f0a0a;
        color: #ef4444;
        border: 1px solid #3d1515;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
        margin-bottom: 1rem;
    }

    .val-error {
        color: #ef4444;
        font-size: 12px;
        margin-top: -0.75rem;
        margin-bottom: 0.75rem;
        display: block;
    }
</style>

<div class="login-page">
    <div class="login-card">
        <h1 class="login-title">Bienvenido a PC Hardware Hub</h1>
        <p class="login-subtitle">Inicia sesión o crea una cuenta para continuar</p>

        <div class="tab-container">
            <button class="tab-btn active">Iniciar Sesión</button>
            <button class="tab-btn inactive"
                    onclick="window.location.href='@Url.Action("Crear", "Usuario")'">
                Registrarse
            </button>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">@ViewBag.Error</div>
        }

        <form asp-action="Login" asp-controller="Usuario" method="post">
            @Html.AntiForgeryToken()

            <label class="field-label">Teléfono</label>
            <input asp-for="Telefono" class="field-input" placeholder="Ingresa tu teléfono" />
            <span asp-validation-for="Telefono" class="val-error"></span>

            <label class="field-label">Contraseña</label>
            <input asp-for="Clave" type="password" class="field-input" placeholder="••••••••" />
            <span asp-validation-for="Clave" class="val-error"></span>

            <button type="submit" class="btn-ingresar">Iniciar Sesión</button>
        </form>

        <div class="divider">o</div>

        <button class="btn-invitado"
                onclick="window.location.href='@Url.Action("Index", "Home")'">
            Continuar como invitado
        </button>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}