<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PC Hardware Hub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dark-theme.css" asp-append-version="true" />
</head>
<body style="margin:0; padding:0; font-family: sans-serif;">

@{
    var sesion = Context.Request.Cookies["UsuarioLogin"];
    var rol = Context.Request.Cookies["UsuarioRol"];
    var esAdmin = rol == "1";
    var rutaActual = Context.Request.Path.Value ?? "";
    var enAdmin = rutaActual.StartsWith("/Admin");
}

@if (esAdmin && enAdmin)
{
    <style>
        .admin-navbar {
            background: #060d1a;
            border-bottom: 1px solid #0f2240;
            padding: 0 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 58px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .admin-logo {
            color: #3b82f6;
            font-size: 15px;
            font-weight: 700;
            text-decoration: none;
        }
        .admin-nav-right {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .btn-tienda {
            color: #3b82f6;
            font-size: 13px;
            padding: 6px 14px;
            border-radius: 6px;
            border: 1px solid #1e3a5f;
            background: transparent;
            text-decoration: none;
            display: inline-block;
        }
        .btn-tienda:hover { background: #0f2240; color: #3b82f6; }
        .btn-logout {
            color: #ef4444;
            font-size: 13px;
            padding: 6px 14px;
            border-radius: 6px;
            border: 1px solid #2a0a0a;
            background: transparent;
            text-decoration: none;
            display: inline-block;
        }
        .btn-logout:hover { background: #1a0505; color: #ef4444; }
        .admin-body {
            background: #080f1a;
            min-height: calc(100vh - 58px);
            padding: 2.5rem;
        }
    </style>

    <nav class="admin-navbar">
        <a href="@Url.Action("Index", "Home")" class="admin-logo">PC Hardware Hub</a>
        <div class="admin-nav-right">
            <a href="@Url.Action("Index", "Home")" class="btn-tienda">🛒 Ver Tienda</a>
            <a href="@Url.Action("Logout", "Usuario")" class="btn-logout">🚪 Cerrar Sesión</a>
        </div>
    </nav>

    <div class="admin-body">
        @RenderBody()
    </div>
}
else
{
    <style>
        .navbar-store {
            background: #060d1a;
            border-bottom: 1px solid #1e3a5f;
            padding: 0 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 64px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .nav-links a {
            color: #94a3b8;
            text-decoration: none;
            font-size: 14px;
            margin-left: 2rem;
        }
        .nav-links a:hover { color: #60a5fa; }
        .user-menu-wrapper { position: relative; }
        .user-menu-btn {
            background: #1e3a5f;
            border: none;
            border-radius: 8px;
            padding: 8px 14px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            color: #f1f5f9;
            font-size: 14px;
        }
        .user-menu-btn:hover { background: #1e40af; }
        .user-dropdown {
            display: none;
            position: absolute;
            right: 0;
            top: calc(100% + 8px);
            background: #0f2240;
            border: 1px solid #1e3a5f;
            border-radius: 10px;
            min-width: 180px;
            overflow: hidden;
            z-index: 200;
        }
        .user-dropdown.open { display: block; }
        .dropdown-item {
            display: block;
            padding: 12px 16px;
            color: #94a3b8;
            text-decoration: none;
            font-size: 14px;
            border-bottom: 1px solid #1e3a5f;
        }
        .dropdown-item:last-child { border-bottom: none; }
        .dropdown-item:hover { background: #162d4a; color: #f1f5f9; }
        .dropdown-item.danger { color: #ef4444; }
        .dropdown-item.danger:hover { background: #1a0a0a; }
        .carrito-btn {
            background: #1e3a5f;
            color: #60a5fa;
            border: none;
            padding: 8px 14px;
            border-radius: 8px;
            font-size: 13px;
            cursor: pointer;
            margin-left: 8px;
        }
        .carrito-btn:hover { background: #1e40af; }
    </style>

    <nav class="navbar-store">
        <a href="@Url.Action("Index", "Home")" style="color:#60a5fa; font-size:1.1rem; font-weight:700; text-decoration:none;">
            PC Hardware Hub
        </a>
        <div class="nav-links">
            <a href="@Url.Action("Index", "Home")">Inicio</a>
            <a href="#catalogo">Catálogo</a>
        </div>
        <div style="display:flex; align-items:center; gap:8px;">
            @if (sesion == null)
            {
                <div class="user-menu-wrapper">
                    <button class="user-menu-btn" onclick="toggleMenu()">👤</button>
                    <div class="user-dropdown" id="userDropdown">
                        <a href="/Usuario/Login" class="dropdown-item">🔑 Iniciar sesión</a>
                        <a href="/Usuario/Crear" class="dropdown-item">📝 Registrarse</a>
                    </div>
                </div>
            }
            else if (esAdmin)
            {
                <div class="user-menu-wrapper">
                    <button class="user-menu-btn" onclick="toggleMenu()">👤 <span style="color:#60a5fa; font-size:13px;">Admin</span></button>
                    <div class="user-dropdown" id="userDropdown">
                        <a href="/Admin/Index" class="dropdown-item">🏠 Panel Admin</a>
                        <a href="/Usuario/Logout" class="dropdown-item danger">🚪 Cerrar sesión</a>
                    </div>
                </div>
            }
            else
            {
                <div class="user-menu-wrapper">
                    <button class="user-menu-btn" onclick="toggleMenu()">👤 <span style="color:#60a5fa; font-size:13px;" id="nombreUsuario">Mi cuenta</span></button>
                    <div class="user-dropdown" id="userDropdown">
                        <a href="/Perfil/Index" class="dropdown-item">👤 Mi perfil</a>
                        <a href="/Puntos/Index" class="dropdown-item">🎁 Mis puntos</a>
                        <a href="/Usuario/Logout" class="dropdown-item danger">🚪 Cerrar sesión</a>
                    </div>
                </div>
            }
            <button class="carrito-btn" onclick="verCarrito()">
                🛒 <span id="carritoCount">0</span>
            </button>
        </div>
    </nav>

    @RenderBody()
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    function toggleMenu() {
        const dropdown = document.getElementById('userDropdown');
        if (dropdown) dropdown.classList.toggle('open');
    }
    document.addEventListener('click', function(e) {
        const wrapper = document.querySelector('.user-menu-wrapper');
        if (wrapper && !wrapper.contains(e.target)) {
            const dropdown = document.getElementById('userDropdown');
            if (dropdown) dropdown.classList.remove('open');
        }
    });
    function actualizarCarrito() {
        const carrito = JSON.parse(localStorage.getItem('carrito') || '[]');
        const total = carrito.reduce((sum, p) => sum + p.cantidad, 0);
        const el = document.getElementById('carritoCount');
        if (el) el.textContent = total;
    }
    function verCarrito() {
        const carrito = JSON.parse(localStorage.getItem('carrito') || '[]');
        if (carrito.length === 0) { alert('Tu carrito está vacío'); return; }
        let msg = 'Carrito:\n\n';
        let total = 0;
        carrito.forEach(p => {
            msg += `${p.nombre} x${p.cantidad} = $${p.precio * p.cantidad}\n`;
            total += p.precio * p.cantidad;
        });
        msg += `\nTotal: $${total}`;
        alert(msg);
    }
    const nombreCookie = document.cookie.split('; ').find(r => r.startsWith('UsuarioNombre='));
    if (nombreCookie) {
        const nombre = nombreCookie.split('=')[1];
        const el = document.getElementById('nombreUsuario');
        if (el) el.textContent = 'Hola, ' + decodeURIComponent(nombre);
    }
    actualizarCarrito();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>