@model SistemadeVentas.EN.Venta
@{
    ViewData["Title"] = "Eliminar Venta";
}

<h2>¿Eliminar esta venta?</h2>
<div class="card bg-dark text-white p-3">
    <p><strong>Usuario:</strong> @(Model.Usuario?.Nombre ?? "Sin usuario")</p>
    <p><strong>Fecha:</strong> @Model.FechaVenta.ToString("dd/MM/yyyy")</p>
    <p><strong>Total:</strong> @Model.Total</p>
    <p><strong>Estado:</strong> @Model.Estado</p>
</div>
<form asp-action="EliminarConfirmado" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input name="id" type="hidden" value="@Model.IdVenta" />
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>