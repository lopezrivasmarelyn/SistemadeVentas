@model SistemadeVentas.EN.Venta
@{
    ViewData["Title"] = "Modificar Venta";
}

<h2>Modificar Venta</h2>
<form asp-action="Modificar" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="IdVenta" type="hidden" />
    <div class="mb-3">
        <label class="form-label">ID Usuario</label>
        <input asp-for="IdUsuario" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Fecha Venta</label>
        <input asp-for="FechaVenta" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Total</label>
        <input asp-for="Total" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Tipo de Pago</label>
        <select asp-for="TipoPago" class="form-control">
            <option value="Efectivo">Efectivo</option>
            <option value="Tarjeta">Tarjeta</option>
            <option value="Transferencia">Transferencia</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Estado</label>
        <select asp-for="Estado" class="form-control">
            <option value="Completada">Completada</option>
            <option value="Pendiente">Pendiente</option>
            <option value="Cancelada">Cancelada</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>