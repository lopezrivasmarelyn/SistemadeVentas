@model List<SistemadeVentas.EN.Venta>
@{
    ViewData["Title"] = "Ventas";
}

<h2>Gestión de Ventas</h2>
<a asp-action="Crear" class="btn btn-primary mb-3">+ Nueva Venta</a>

<table class="table table-dark table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Usuario</th>
            <th>Fecha</th>
            <th>Total</th>
            <th>Tipo Pago</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdVenta</td>
                <td>@(item.Usuario?.Nombre ?? "Sin usuario")</td>
                <td>@item.FechaVenta.ToString("dd/MM/yyyy")</td>
                <td>@item.Total</td>
                <td>@item.TipoPago</td>
                <td>@item.Estado</td>
                <td>
                    <a asp-action="Modificar" asp-route-id="@item.IdVenta" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Eliminar" asp-route-id="@item.IdVenta" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>