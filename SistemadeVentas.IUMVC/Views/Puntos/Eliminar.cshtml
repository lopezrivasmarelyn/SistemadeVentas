@model SistemadeVentas.EN.Puntos
@{
    ViewData["Title"] = "Eliminar Puntos";
}

<h2>¿Eliminar este registro?</h2>
<div class="card bg-dark text-white p-3">
    <p><strong>Usuario:</strong> @(Model.Usuario?.Nombre ?? "Sin usuario")</p>
    <p><strong>Puntos:</strong> @Model.PuntosAcumulados</p>
    <p><strong>Código:</strong> @Model.CodigoDescuento</p>
</div>
<form asp-action="EliminarConfirmado" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input name="id" type="hidden" value="@Model.IdPuntos" />
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>