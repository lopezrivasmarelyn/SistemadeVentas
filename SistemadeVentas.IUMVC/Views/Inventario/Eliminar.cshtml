@model SistemadeVentas.EN.Inventario
@{
    ViewData["Title"] = "Eliminar Inventario";
}

<h2>¿Eliminar este registro?</h2>
<div class="card bg-dark text-white p-3">
    <p><strong>Producto:</strong> @(Model.Producto?.Nombre ?? "Sin producto")</p>
    <p><strong>Stock Anual:</strong> @Model.StockAnual</p>
    <p><strong>Stock Mínimo:</strong> @Model.StockMinimo</p>
</div>
<form asp-action="EliminarConfirmado" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input name="id" type="hidden" value="@Model.IdInventario" />
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>