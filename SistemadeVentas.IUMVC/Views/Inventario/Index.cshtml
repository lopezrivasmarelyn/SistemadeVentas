@model List<SistemadeVentas.EN.Inventario>
@{
    ViewData["Title"] = "Inventario";
}

<h2>Gestión de Inventario</h2>
<a asp-action="Crear" class="btn btn-primary mb-3">+ Nuevo Registro</a>

<table class="table table-dark table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Producto</th>
            <th>Stock Anual</th>
            <th>Stock Mínimo</th>
            <th>Última Actualización</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdInventario</td>
                <td>@(item.Producto?.Nombre ?? "Sin producto")</td>
                <td>@item.StockAnual</td>
                <td>@item.StockMinimo</td>
                <td>@item.UltimaActualizacion.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Modificar" asp-route-id="@item.IdInventario" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Eliminar" asp-route-id="@item.IdInventario" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>