@model IEnumerable<Rol>

@{
    ViewData["Title"] = "Roles";
}

<h1 class="page-title">Gestión de Roles</h1>
<p class="page-subtitle">Administra los roles del sistema.</p>

@if (TempData["Exito"] != null)
{
    <div class="alert-dark-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-dark-error">@TempData["Error"]</div>
}

<!-- BOTÓN AGREGAR -->
<div style="display:flex; justify-content:flex-end; margin-bottom:1rem;">
    <button class="btn-purple" data-bs-toggle="modal" data-bs-target="#modalCrear">
        + Agregar Rol
    </button>
</div>

<!-- TABLA -->
<div class="card-dark" style="padding:0;">
    <table class="table-dark">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th style="text-align:right;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rol in Model)
            {
                <tr>
                    <td style="color:#a0a0a0;">@rol.IdRol</td>
                    <td>@rol.Nombre</td>
                    <td style="text-align:right;">
                        <button class="btn-icon"
                                onclick="abrirModalModificar(@rol.IdRol, '@rol.Nombre')"
                                title="Modificar">
                            ✏️
                        </button>
                        <button class="btn-icon btn-icon-danger"
                                onclick="abrirModalEliminar(@rol.IdRol, '@rol.Nombre')"
                                title="Eliminar">
                            🗑️
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- MODAL (PAGINA ENCIMA DE INDEX) CREAR -->
<div class="modal fade modal-dark" id="modalCrear" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Agregar Rol</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Crear" asp-controller="Rol" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <label class="form-label-dark">Nombre del Rol</label>
                    <input type="text" name="Nombre" class="form-input-dark" placeholder="Ej. Administrador" required />
                    @if (ViewBag.ErrorCrear != null)
                    {
                        <div class="alert-dark-error">@ViewBag.ErrorCrear</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-outline-dark" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-purple">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL MODIFICAR -->
<div class="modal fade modal-dark" id="modalModificar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Modificar Rol</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Modificar" asp-controller="Rol" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="modificarIdRol" name="IdRol" />
                    <label class="form-label-dark">Nombre del Rol</label>
                    <input type="text" id="modificarNombre" name="Nombre" class="form-input-dark" required />
                    @if (ViewBag.ErrorModificar != null)
                    {
                        <div class="alert-dark-error">@ViewBag.ErrorModificar</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-outline-dark" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-purple">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL ELIMINAR -->
<div class="modal fade modal-dark" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Eliminar Rol</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p style="color:#d0d0d0;">¿Estás seguro que deseas eliminar el rol <strong id="eliminarNombre" style="color:white;"></strong>?</p>
                <p style="color:#a0a0a0; font-size:0.875rem;">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <form asp-action="EliminarConfirmado" asp-controller="Rol" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="eliminarIdRol" name="id" />
                    <button type="button" class="btn-outline-dark" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" style="background-color:#ef4444; color:white; border:none; border-radius:8px; padding:0.75rem 1.5rem; cursor:pointer;">
                        Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function abrirModalModificar(id, nombre) {
            document.getElementById('modificarIdRol').value = id;
            document.getElementById('modificarNombre').value = nombre;
            new bootstrap.Modal(document.getElementById('modalModificar')).show();
        }

        function abrirModalEliminar(id, nombre) {
            document.getElementById('eliminarIdRol').value = id;
            document.getElementById('eliminarNombre').innerText = nombre;
            new bootstrap.Modal(document.getElementById('modalEliminar')).show();
        }
    </script>
}