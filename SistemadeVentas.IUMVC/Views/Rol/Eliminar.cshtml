@model SistemadeVentas.EN.Rol
@{
    ViewData["Title"] = "Eliminar Rol";
}

<h2>¿Eliminar este rol?</h2>
<div class="card bg-dark text-white p-3">
    <p><strong>Nombre:</strong> @Model.Nombre</p>
</div>
<form asp-action="EliminarConfirmado" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input name="id" type="hidden" value="@Model.IdRol" />
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>