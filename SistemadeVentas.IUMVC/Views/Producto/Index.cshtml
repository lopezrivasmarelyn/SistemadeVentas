@model List<Producto>

@{
    ViewData["Title"] = "Productos";
}

<style>
    .btn-morado {
        background-color: #a855f7 !important;
        color: white !important;
        border: none !important;
        border-radius: 8px !important;
        padding: 8px 16px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.2s;
        text-decoration: none;
        margin: 8px 16px 0 0;
    }
    .btn-morado:hover { background-color: #9333ea !important; }
    .box { display: flex; align-items: center; justify-content: space-between; width: 100%; }
    .tittle { text-align: center; margin: auto; }
</style>

<div class="box">
    <div class="tittle">
        <h1 class="page-title">Gestión de Productos</h1>
        <p class="page-subtitle">Administra los productos del sistema.</p>
    </div>
    <div>
        <a href="@Url.Action("Crear", "Producto")" class="btn-morado">
            + Nuevo Producto
        </a>
    </div>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert-dark-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-dark-error">@TempData["Error"]</div>
}

<div class="card-dark" style="padding:0; margin:10px;">
    <table class="table-dark">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Precio</th>
                <th>Categoría</th>
                <th>Estado</th>
                <th style="text-align:right;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color:#a0a0a0;">@item.IdProducto</td>
                    <td>@item.Nombre</td>
                    <td style="color:#a0a0a0;">@item.Descripcion</td>
                    <td>$@item.Precio</td>
                    <td>
                        <span class="badge-dark">@(item.Categoria?.Nombre ?? "Sin categoría")</span>
                    </td>
                    <td>
                        <span style="color: @(item.Estado == "Activo" ? "#4ade80" : "#f87171")">
                            @item.Estado
                        </span>
                    </td>
                    <td style="text-align:right;">
                        <a href="@Url.Action("Modificar", "Producto", new { id = item.IdProducto })"
                           class="btn-icon" title="Modificar">✏️</a>
                        <a href="@Url.Action("Eliminar", "Producto", new { id = item.IdProducto })"
                           class="btn-icon btn-icon-danger" title="Eliminar">🗑️</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>