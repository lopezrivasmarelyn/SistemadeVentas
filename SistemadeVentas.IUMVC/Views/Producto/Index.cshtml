@model List<SistemadeVentas.EN.Producto>
@{
    ViewData["Title"] = "Productos";
}

<h2>Gestión de Productos</h2>
<a asp-action="Crear" class="btn btn-primary mb-3">+ Nuevo Producto</a>

<table class="table table-dark table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Categoría</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdProducto</td>
                <td>@item.Nombre</td>
                <td>@item.Descripcion</td>
                <td>@item.Precio</td>
                <td>@(item.Categoria?.Nombre ?? "Sin categoría")</td>
                <td>@item.Estado</td>
                <td>
                    <a asp-action="Modificar" asp-route-id="@item.IdProducto" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Eliminar" asp-route-id="@item.IdProducto" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>