@model SistemadeVentas.EN.Producto
@{
    ViewData["Title"] = "Eliminar Producto";
}

<h2>¿Eliminar este producto?</h2>
<div class="card bg-dark text-white p-3">
    <p><strong>Nombre:</strong> @Model.Nombre</p>
    <p><strong>Precio:</strong> @Model.Precio</p>
    <p><strong>Estado:</strong> @Model.Estado</p>
</div>
<form asp-action="EliminarConfirmado" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input name="id" type="hidden" value="@Model.IdProducto" />
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>