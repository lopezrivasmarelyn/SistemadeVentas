@model List<SistemadeVentas.EN.Categoria>
@{
    ViewData["Title"] = "Categorías";
}

<h2>Gestión de Categorías</h2>
<a asp-action="Crear" class="btn btn-primary mb-3">+ Nueva Categoría</a>

<table class="table table-dark table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdCategoria</td>
                <td>@item.Nombre</td>
                <td>@item.Descripcion</td>
                <td>@item.Estado</td>
                <td>
                    <a asp-action="Modificar" asp-route-id="@item.IdCategoria" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Eliminar" asp-route-id="@item.IdCategoria" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>